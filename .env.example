# ============================================
# Self-Leveling (我独自升级) - 环境变量模板
# ============================================
# 使用说明：
# 1. 复制此文件为 .env.local
# 2. 填写实际值
# 3. 不要提交 .env.local 到版本控制
# ============================================

# ============================================
# 数据库配置 (PostgreSQL)
# ============================================
DATABASE_URL="postgresql://username:password@host:5432/self_leveling?schema=public"

# ============================================
# Redis 配置 (可选，用于会话缓存)
# ============================================
REDIS_URL="redis://localhost:6379"
REDIS_TOKEN="your-redis-token"

# ============================================
# AI API 配置 (OpenAI 或 Claude)
# ============================================
# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_ORGANIZATION="org-..."

# Claude (Anthropic)
CLAUDE_API_KEY="sk-ant-..."

# AI 模型配置
AI_MODEL="gpt-4"
AI_MAX_TOKENS="2000"
AI_TEMPERATURE="0.7"

# ============================================
# 认证配置
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_DEBUG="false"

# Google OAuth (可选)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth (可选)
GITHUB_ID=""
GITHUB_SECRET=""

# ============================================
# 邮件服务配置
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="Self-Leveling <noreply@selfleveling.app>"

# ============================================
# 应用配置
# ============================================
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Self-Leveling"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_DESCRIPTION="让成长变成一场冒险，把目标变成可以打败的怪物"

# 日志级别
LOG_LEVEL="info"

# ============================================
# 第三方服务配置
# ============================================
# S3/R2 存储 (可选，用于文件上传)
S3_BUCKET_NAME=""
S3_BUCKET_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""

# ============================================
# 安全配置
# ============================================
# 速率限制
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="60000"

# CORS 域名白名单
ALLOWED_ORIGINS="http://localhost:3000,https://selfleveling.app"

# ============================================
# Vercel 特定环境变量 (在 Vercel 控制台设置)
# ============================================
# FRAMEWORK_PRESET="nextjs"
# VERCEL_GIT_COMMIT_SHA="..."

# ============================================
# 开发环境专用
# ============================================
# Skip Prisma migrations in development
SKIP_ENV_CREATION="false"
